    <script>
        lucide.createIcons();

        // Advertisement Controls
        function closeAd() {
            document.getElementById('ad-container').classList.add('slide-out');
        }

        function toggleMasterAds(checkbox) {
            const adContainer = document.getElementById('ad-container');
            if (checkbox.checked) {
                adContainer.style.display = 'flex';
                // Delay removing slide-out slightly to allow display:flex to apply first for transition
                setTimeout(() => adContainer.classList.remove('slide-out'), 10);
            } else {
                adContainer.style.display = 'none';
            }
        }

        function toggleTurboAds(checkbox) {
            const turboContainer = document.getElementById('turbo-ad-container');
            
            if (checkbox.checked) {
                // Turn Turbo Mode ON: Inject scripts dynamically
                turboContainer.innerHTML = '<div id="container-d86ba687c26fa8d5d6f109ee0bb1a5cc"></div>';
                
                let script1 = document.createElement('script');
                script1.async = true;
                script1.dataset.cfasync = "false";
                script1.src = "https://pl28905166.effectivegatecpm.com/d86ba687c26fa8d5d6f109ee0bb1a5cc/invoke.js";
                turboContainer.appendChild(script1);

                let script2 = document.createElement('script');
                script2.src = "https://pl28905160.effectivegatecpm.com/94/96/81/94968100b5c8d0d571fbab875ab34b22.js";
                script2.id = "turbo-script-2";
                document.body.appendChild(script2);
            } else {
                // Turn Turbo Mode OFF: Remove scripts
                turboContainer.innerHTML = '';
                let s2 = document.getElementById('turbo-script-2');
                if(s2) s2.remove();
            }
        }

        window.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                const decoy = document.getElementById('studyzone-decoy');
                
                decoy.style.opacity = '0';
                
                setTimeout(() => {
                    decoy.style.display = 'none';
                    document.title = "."; 
                    
                    setTimeout(() => {
                        document.getElementById('themeAnnouncementOverlay').style.display = 'flex';
                    }, 200);

                }, 400);
            }, 1);
        });

        function openSidebar() {
            document.getElementById('sidebar').classList.add('expanded');
            document.getElementById('iframe-wrapper').classList.add('blurred');
        }
        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('expanded');
            document.getElementById('iframe-wrapper').classList.remove('blurred');
        }
        function openSettings() { closeSidebar(); document.getElementById('settingsOverlay').style.display = 'flex'; }
        function closeSettings(e) { if (e.target.id === 'settingsOverlay') document.getElementById('settingsOverlay').style.display = 'none'; }

        window.createSplash = function(targetId = "waveLoaderOverlay") {
            const overlay = document.getElementById(targetId);
            for(let i=0; i<25; i++) {
                setTimeout(() => {
                    const b = document.createElement("div");
                    b.className = "bubble";
                    b.style.left = Math.random() * 100 + "%";
                    b.style.bottom = "95%";
                    const s = Math.random() * 25 + 10 + "px";
                    b.style.width = s; b.style.height = s;
                    overlay.appendChild(b);
                    setTimeout(() => b.remove(), 1200);
                }, i * 40);
            }
        };

        let isPageLoading = false;
        function loadPage(url, title, element) {
            if (isPageLoading) return;
            isPageLoading = true;

            closeSidebar();
            document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
            if(element) element.classList.add('active');

            const overlay = document.getElementById("waveLoaderOverlay");
            const waveContainer = document.getElementById("waveContainer");
            const text = document.getElementById("loadingText");
            const iframe = document.getElementById("mainFrame");
            
            overlay.style.display = "flex";
            void waveContainer.offsetWidth;
            
            waveContainer.style.transition = "transform 0.6s cubic-bezier(0.4, 0, 0.2, 1)";
            waveContainer.style.transform = "translateY(0%)";
            
            text.style.opacity = "1";
            text.innerText = "LOADING " + title.toUpperCase() + "...";

            setTimeout(() => {
                iframe.src = url;
                window.createSplash();
                
                setTimeout(() => {
                    waveContainer.style.transition = "transform 1.2s cubic-bezier(0.65, 0, 0.35, 1)";
                    waveContainer.style.transform = "translateY(calc(100% + 120px))";
                    text.style.opacity = "0";

                    setTimeout(() => {
                        overlay.style.display = "none";
                        isPageLoading = false;
                    }, 1200);
                }, 400); 
            }, 600); 
        }

        let isThemeChanging = false;
        window.triggerThemeWave = function(themeId, announcementMessage, themeVersion) {
            if (isThemeChanging) return;
            isThemeChanging = true;

            const overlay = document.getElementById("themeTransitionOverlay");
            const waveContainer = document.getElementById("themeWaveContainer");
            const iframe = document.getElementById("mainFrame");

            overlay.style.display = "block";
            void waveContainer.offsetWidth; 
            
            waveContainer.style.transition = "transform 0.5s ease-out";
            waveContainer.style.transform = "translateY(0%)";

            setTimeout(() => {
                if (iframe.src) { iframe.src = iframe.src; }

                setTimeout(() => {
                    waveContainer.style.transition = "transform 0.8s cubic-bezier(0.65, 0, 0.35, 1)";
                    waveContainer.style.transform = "translateY(calc(100% + 120px))";
                    
                    setTimeout(() => {
                        overlay.style.display = "none";
                        isThemeChanging = false;
                    }, 800);
                }, 400);
            }, 500);
        }

        function closeAnnouncement() {
            document.getElementById('themeAnnouncementOverlay').style.display = 'none';
        }
    </script>
